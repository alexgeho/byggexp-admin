# One-time nginx setup for admin.byggexp.se (AlmaLinux /etc/nginx/conf.d/admin.conf)
# Replace static root with proxy to the Next.js PM2 process on port 5174.
#
# After editing:
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 443 ssl http2;
    server_name admin.byggexp.se;

    # ssl_certificate /etc/letsencrypt/live/admin.byggexp.se/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/admin.byggexp.se/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:5174;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 80;
    server_name admin.byggexp.se;
    return 301 https://$host$request_uri;
}
