# /etc/nginx/conf.d/admin.conf
#
# Next.js standalone runs under PM2 on 127.0.0.1:5174.
# nginx must proxy ALL paths (including /_next/static/*) to Node.
#
# IMPORTANT: remove legacy Vite/SPA blocks from the old setup, for example:
#   - root /opt/byggexp-admin/current/dist;
#   - try_files $uri $uri/ /index.html;
#   - location ~* \.(js|css|...)$ { root ...; }
#   - location /_next/ { alias/root ...; }
# Those intercept /_next/static/*.js and return 500/text/plain in the browser.
#
# After editing:
#   sudo nginx -t && sudo systemctl reload nginx
#
# Quick check:
#   curl -sI -H 'Host: admin.byggexp.se' http://127.0.0.1/login | grep -i x-powered-by
#   curl -sI -H 'Host: admin.byggexp.se' http://127.0.0.1/_next/static/chunks/<any-chunk>.js | grep -E 'HTTP|X-Powered-By|Content-Type'

server {
    listen 443 ssl http2;
    server_name admin.byggexp.se;

    access_log /var/log/nginx/byggexp-admin-access.log;
    error_log /var/log/nginx/byggexp-admin-error.log warn;

    ssl_certificate /etc/letsencrypt/live/admin.byggexp.se/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/admin.byggexp.se/privkey.pem;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;

    location / {
        proxy_pass http://127.0.0.1:5174;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 80;
    server_name admin.byggexp.se;
    return 301 https://$host$request_uri;
}
